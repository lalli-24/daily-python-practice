def mostCommonWord(paragraph, banned):
        splited=[]
        word=''
        for x in paragraph:
            if x.isalpha():
                word+=x
            else:
                if word:
                    splited.append(word.lower())
                    word=''
        if word:
            splited.append(word.lower())

        freq={}
        for words in splited:
            if words not in banned:
                freq[words]=freq.get(words,0)+1

        max_val=max(freq.values())

        for key in freq:
            if freq[key]==max_val:
                return key

print(mostCommonWord("Bob hit a ball, the hit BALL flew far after it was hit.",["hit"]))
