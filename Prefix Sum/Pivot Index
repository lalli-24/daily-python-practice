nums = [1,7,3,6,5,6]
prefix=[nums[0]]
for x in range(1,len(nums)):
    prefix.append(nums[x]+prefix[x-1])
print(prefix)

n=len(nums)
for x in range(n):
    if x==0:
        left=0
    else:
        left=prefix[x-1]
    if x==n-1:
        right=0
    else:
        right=prefix[n-1]-prefix[x]

    if left==right:
        print(x)
