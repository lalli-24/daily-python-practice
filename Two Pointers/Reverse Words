def reverseWords(s):
    s=s.split()
    z=0
    for x in s:
        x=list(x)
        i=0
        j=len(x)-1
        while i<j:
            x[i],x[j]=x[j],x[i]
            i+=1
            j-=1
        x="".join(x)
        s[z]=x
        z+=1
    return ' '.join(s)
print(reverseWords("Let's take LeetCode contest"))
