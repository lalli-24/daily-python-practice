def maxArea(height):
        max_water=0
        left=0 
        right=len(height)-1
        while left<right:
            width=right-left
            heig=min(height[left],height[right])
            curr=width*heig
            max_water=max(curr,max_water)
            if height[left]<height[right]:
                left+=1
            else:
                right-=1
        return max_water
print(maxArea([1,8,6,2,5,4,8,3,7]))
