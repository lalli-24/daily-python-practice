# Brute Force

nums=[15,2,6,1,7,9]
leaders=0
for x in range(len(nums)):
    flag=True
    for y in range(x+1,len(nums)):
        if nums[y]>nums[x]:
            flag=False
            break
    if flag:
        leaders+=1
print(leaders)

#Carry Forward Approach

nums=[11,2,6,11,7,9]
leaders=1
maxi=nums[len(nums)-1]
for x in range(len(nums)-2,-1,-1):
    if nums[x]>=maxi:
        leaders+=1
        maxi=nums[x]
print(leaders)
