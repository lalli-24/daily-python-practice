def max_subarray(nums):
    max_sum=nums[0]
    curr_sum=0
    
    for x in range(len(nums)):
        
        curr_sum+=nums[x] 
        
        if curr_sum>max_sum:
            max_sum=curr_sum   
        if curr_sum<=0:
            curr_sum=0

    return max_sum
        
print(max_subarray([-2,-1,-3]))
