def product(nums):
    n=len(nums)

    left=[1]*n
    for x in range(1,n):
        left[x]=nums[x-1]*left[x-1]
    
    right=[1]*n
    for x in range(n-2,-1,-1):
        right[x]=nums[x+1]*right[x+1]
        
    result=[]
    for x in range(n):
        result.append(left[x]*right[x])
    
    return result

print(product(nums = [1,2,3,4]))
