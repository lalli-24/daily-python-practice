mat=[
    [1,2,3],
    [4,5,6],
    [7,8,9]
    ]
rows=len(mat)
cols=len(mat[0])
print(rows,cols)


for x in range(rows):
    for y in range(x,cols):
        mat[x][y],mat[y][x]=mat[y][x],mat[x][y]
print(mat)

for row in mat:
    l=0
    r=len(row) - 1

    while l<r:
        row[l],row[r]=row[r],row[l]
        l += 1
        r -= 1
print(mat)
