def anagram(s,t):
    d={}
    if len(s) != len(t):
        return False
    for x in s:
        if x not in d:
            d[x]=1
        else:
            d[x]+=1
          
    for x in t:
        if x in d:
            d[x]-=1
            if d[x]==0:
                d.pop(x)
        else:
            return False
          
    if not d:
        return True
    else:
        return False
print(anagram(s = "aacc",t = "ccaa"))
