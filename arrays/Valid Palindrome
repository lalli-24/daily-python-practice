def palindrome(s):
    s=s.lower()
    str1=''
    for x in s:
        if ('a'<=x<='z') or ('0'<=x<='9'):
            str1+=x

    i=0
    j=len(str1)-1
    while i<j:
        if str1[i]!=str1[j]:
            return False
        i+=1
        j-=1
    return True
            
print(palindrome(s = "A man, a plan, a canal: Panama"))
